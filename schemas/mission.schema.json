{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anomaly-os.dev/schemas/mission.schema.json",
  "title": "AnomalyOS Mission",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "outcome", "status", "risk", "acceptanceCriteria", "constraints", "evidence"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$" },
    "title": { "type": "string", "minLength": 3 },
    "outcome": { "type": "string", "minLength": 10 },
    "status": {
      "enum": ["draft", "planned", "approved", "executing", "verifying", "review", "completed", "blocked", "failed"]
    },
    "risk": { "enum": ["low", "medium", "high", "critical"] },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "statement", "status"],
        "properties": {
          "id": { "type": "string" },
          "statement": { "type": "string", "minLength": 5 },
          "status": { "enum": ["pending", "satisfied", "failed", "waived"] },
          "evidenceIds": { "type": "array", "items": { "type": "string" } },
          "waiverReason": { "type": "string" }
        }
      }
    },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "plan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "status"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "status": { "enum": ["pending", "active", "completed", "blocked", "skipped"] }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "summary", "recordedAt"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "enum": ["test", "command", "diff", "analysis", "review", "approval", "waiver"] },
          "summary": { "type": "string" },
          "command": { "type": "string" },
          "exitCode": { "type": "integer" },
          "recordedAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
